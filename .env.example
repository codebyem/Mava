# ── Strava API ────────────────────────────────────────────────
# Create your app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Callback URL registered in your Strava app settings
STRAVA_REDIRECT_URI=http://localhost:5000/callback

# ── Flask ──────────────────────────────────────────────────────
# Generate a strong random key, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=8e1fb104b029a49a242b1b5969b39c4c09275ee3e0657b4757d6ac0579d5da6a

# Optional: set to 'true' to enable debug mode locally
FLASK_DEBUG=false
